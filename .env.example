# =====================================================================
# VITAS · Football Intelligence — Variables de Entorno
# =====================================================================
# Copia este archivo como .env (desarrollo) o configura en Vercel (producción)
# =====================================================================

# ── Supabase (Fase 3) ─────────────────────────────────────────────────
# Dashboard: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica

# ── Anthropic (Agentes IA) ────────────────────────────────────────────
# Solo en Vercel (server-side). NO agregar VITE_ prefix (no exponer al cliente)
ANTHROPIC_API_KEY=sk-ant-...

# ── Bunny Stream (Fase 2 — Videos) ───────────────────────────────────
# Dashboard: https://dash.bunny.net → Stream → Library → API Access
BUNNY_STREAM_LIBRARY_ID=123456
BUNNY_STREAM_API_KEY=tu-library-api-key
BUNNY_CDN_HOSTNAME=tu-hostname.b-cdn.net

# ── Bunny Storage (Fase 2 — Imágenes) ───────────────────────────────
# Dashboard: https://dash.bunny.net → Storage → tu-zona
BUNNY_STORAGE_ZONE=vitas-images
BUNNY_STORAGE_API_KEY=tu-storage-api-key
BUNNY_STORAGE_CDN_URL=https://vitas-images.b-cdn.net

# ── Roboflow (Fase 2 — Detección de jugadores) ───────────────────────
# Dashboard: https://app.roboflow.com → tu-proyecto → Deploy
ROBOFLOW_API_KEY=tu-roboflow-api-key
ROBOFLOW_WORKSPACE=tu-workspace
ROBOFLOW_PROJECT=football-players
ROBOFLOW_VERSION=1
