{
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/notifications/cron",
      "schedule": "0 9 * * *"
    }
  ],
  "functions": {
    "api/agents/*.ts":   { "maxDuration": 60 },
    "api/pipeline/*.ts": { "maxDuration": 60 },
    "api/tracking/*.ts": { "maxDuration": 60 }
  }
}
